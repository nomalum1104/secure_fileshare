# ──────────────────────────────────────────────────────────────────
# Bu faylni .env ga nusxa oling va qiymatlarni to'ldiring
# Railway da: Settings → Variables bo'limiga kiriting
# ──────────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────────────
# Tasodifiy kalit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secret-flask-key-here

# ── PostgreSQL (Railway avtomatik beradi) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Shifrlash kaliti (AES-256) ─────────────────────────────────────
# Kalit yaratish: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# ── Cloudflare R2 yoki AWS S3 ─────────────────────────────────────
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=auto

# Cloudflare R2 uchun (S3 uchun bo'sh qoldiring):
S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# ── Email SMTP (Gmail misoli) ──────────────────────────────────────
# Gmail: Google Account → Security → App Passwords → yarating
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-16-chars
SMTP_FROM=your-email@gmail.com
